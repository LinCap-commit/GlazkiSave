<Window x:Class="ГлазаЗеркалоДуши.PriorityDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ГлазаЗеркалоДуши"
        mc:Ignorable="d"
        Title="Изменить приоритет" Height="150" Width="300" FontFamily="Century Gothic" WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBlock Text="Изменить приоритет на..." VerticalAlignment="Top" Margin="10,10,10,0" Width="auto" Height="25"></TextBlock>
        <TextBox Height="25" FontSize="20" Width="150" HorizontalAlignment="Left" Margin="20" Name="PriorBox"/>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <Button Width="80" Content="ОК" Height="25" FontSize="17" Name="OK" Click="OK_Click"></Button>
            <Button Width="80" Content="Отмена" Height="25" FontSize="17" IsCancel="True"></Button>
        </StackPanel>
    </Grid>
</Window>
