<Page x:Class="ГлазаЗеркалоДуши.AgentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ГлазаЗеркалоДуши"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="AgentPage" FontFamily="Century Gothic" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="Поиск:  " TextAlignment="Right" Width="auto" FontSize="15" VerticalAlignment="Center"></TextBlock>
            <TextBox Name="SearchBox" TextChanged="SearchBox_TextChanged" Width="200" Height="20"></TextBox>

            <ComboBox Name="SortBox" Width="170" Margin="12,0" SelectionChanged="SortBox_SelectionChanged" Height="25" FontSize="15" VerticalAlignment="Center">
                <TextBlock>Без сортировки</TextBlock>
                <TextBlock>По наименованиям (Возр)</TextBlock>
                <TextBlock>По наименованиям (Убыв)</TextBlock>
                <TextBlock>По скидке (Возр)</TextBlock>
                <TextBlock>По скидке (Убыв)</TextBlock>
                <TextBlock>По приоритету (Возр)</TextBlock>
                <TextBlock>По приоритету (Убыв)</TextBlock>
            </ComboBox>

            <ComboBox Name="FilterBox" Width="120" SelectionChanged="FilterBox_SelectionChanged" Height="25" FontSize="15" VerticalAlignment="Center">
                <TextBlock>Все</TextBlock>
                <TextBlock>МФО</TextBlock>
                <TextBlock>ООО</TextBlock>
                <TextBlock>ЗАО</TextBlock>
                <TextBlock>МКК</TextBlock>
                <TextBlock>ОАО</TextBlock>
                <TextBlock>ПАО</TextBlock>
            </ComboBox>

            <Button Name="AddBtn" Content="Добавить агента" FontSize="17" Width="160" VerticalContentAlignment="Center" Margin="10,0" Height="25" Click="AddBtn_Click"/>
            <Button Name="PriorChangeBtn" Content="Изменить приоритет на..." FontSize="17" Width="auto" VerticalContentAlignment="Center" Height="25" Click="PriorChangeBtn_Click"></Button>
        </StackPanel>

        <ListView Name="AgentListView" Grid.Row="1" SelectionMode="Multiple" SelectionChanged="AgentListView_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="BorderBrush" Value="#FFAAAAAA"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Margin" Value="1.5"/>
                    <Setter Property="Background" Value="{Binding BackColor}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="600"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Image Grid.Column="0" Grid.Row="0" Stretch="UniformToFill" Grid.RowSpan="4" HorizontalAlignment="Center" Margin="5">
                            <Image.Source>
                                <Binding Path="LogoPath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>
                                            image/picture.png
                                        </ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>
                        
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="{Binding AgentType.Title}" FontSize="20"></TextBlock>
                            <TextBlock Text="{Binding Title, StringFormat= | {0}}" FontSize="20"></TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Sales, StringFormat={}{0} продаж за год}" FontSize="20"></TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Phone}" FontSize="20"></TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Priority, StringFormat=Приоритетность: {0}}" FontSize="20"></TextBlock>
                        <TextBlock Grid.Column="2" Grid.Row="2" Text="{Binding Discount, StringFormat={}{0}%}" FontSize="25" HorizontalAlignment="Left"/>

                        <Button Grid.Column="1" Grid.Row="3" HorizontalAlignment="Right" Content="Редактировать" Name="EditBtn" Width="160" Height="30" Click="EditBtn_Click"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="PageBackBtn" Content="&lt;" Width="20" Height="20" Click="PageBackBtn_Click"></Button>
            <ListBox FontSize="20" Name="PageList" MouseUp="PageList_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="PageForwBtn" Content="&gt;" Width="20" Height="20" Click="PageForwBtn_Click"></Button>
        </StackPanel>
        
    </Grid>
</Page>
